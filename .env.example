# WeatherAPI (Optional - Free Tier: 1M calls/month)
VITE_WEATHERAPI_KEY=your_weatherapi_key_here

# OpenWeatherMap (Optional - Free Tier: 1,000 calls/day)
VITE_OPENWEATHERMAP_KEY=your_openweathermap_key_here

# Visual Crossing (Optional - Free Tier: 1,000 calls/day)
VITE_VISUALCROSSING_KEY=your_visualcrossing_key_here

# Pirate Weather (Optional - Free Tier: 20,000 calls/month)
VITE_PIRATEWEATHER_KEY=your_pirateweather_key_here

# Tomorrow.io (Optional - Free Tier: 500 calls/day)
VITE_TOMORROWIO_KEY=your_tomorrowio_key_here

# Weatherbit (Optional - Free Tier: 500 calls/day)
VITE_WEATHERBIT_KEY=your_weatherbit_key_here

# MET Norway, 7Timer!, Open-Meteo, wttr.in do NOT require keys.
